# =============================================================================
# unionV2 environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
# Staging URL during development; production domain at cutover (see plan §18.3).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (fresh v2 project — separate from v1)
# -----------------------------------------------------------------------------
# Get from Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses RLS — server-only, never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Resend (transactional + content emails)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM="Union <noreply@your-domain.mn>"

# -----------------------------------------------------------------------------
# Vercel Cron authentication
# -----------------------------------------------------------------------------
# Long random string. Vercel injects this into Authorization headers for its
# own cron calls (see /api/cron/* routes). Generate with: openssl rand -hex 32
CRON_SECRET=

# -----------------------------------------------------------------------------
# Cloudflare R2 (self-hosted video storage)
# -----------------------------------------------------------------------------
# Get account ID from Cloudflare Dashboard → R2 → Overview (right sidebar).
R2_ACCOUNT_ID=
# Create an R2 API token: Dashboard → R2 → Manage R2 API Tokens → Create.
# Permission: Object Read & Write. Scope: bucket "union-videos".
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=union-videos
# Format: https://<account_id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Optional — only if you bind a custom domain to the R2 bucket.
# Leave blank to use presigned cloudflarestorage.com URLs.
# R2_PUBLIC_HOST=videos.your-domain.mn
